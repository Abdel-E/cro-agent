# Copy to .env and fill in your key:
#   cp .env.example .env
#
# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

COPY_GENERATOR_BACKEND=gemini
GEMINI_MODEL=gemini-2.5-flash

# Default to mock for the live sandbox; change to "gemini" only if you want to test LLM insights manually
AGENT_REASONER_BACKEND=mock
AGENT_REASONER_MODEL=gemini-2.5-flash
